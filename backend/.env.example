# Copy to backend/.env for local development. NEVER commit real secrets.

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — the Vite dev server origin(s)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage (defaults to backend/data/)
# DJANGO_DATA_DIR=/data
# DJANGO_DB_PATH=/data/db.sqlite3

# Uploads
MAX_ATTACHMENT_SIZE=5242880

# --- Production only ---
# CSRF_TRUSTED_ORIGINS=https://your-frontend.example
# DJANGO_SECURE_SSL_REDIRECT=true
